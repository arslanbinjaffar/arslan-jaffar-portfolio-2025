# --- Local dev (copy to .env.local, gitignored) ---
VITE_SITE_URL=http://localhost:3000
VITE_NOINDEX=true
VITE_WHATSAPP_NUMBER=923271064839
VITE_FACEBOOK_MESSENGER_USERNAME=arslanbinjaffar
VITE_INSTAGRAM_USERNAME=arslanbinjaffar
VITE_GITHUB_USERNAME=arslanbinjaffar

# =============================================================================
# Environment variables — copy relevant section to .env.local for local dev
# =============================================================================

# --- Local dev (copy to .env.local, gitignored) ---
VITE_SITE_URL=http://localhost:3000
VITE_NOINDEX=true

# --- Vercel Production (branch: main) ---
# Set in Vercel Dashboard → Environment Variables → Production scope:
# VITE_SITE_URL=https://arslan-jaffar-portfolio.vercel.app
# VITE_NOINDEX=false  (or leave unset)

# --- Vercel Staging (branch: staging, Preview scope) ---
# Stable staging URL: https://arslan-jaffar-portfolio-git-staging-<team>.vercel.app
# Set in Vercel Dashboard → Environment Variables → Preview (branch: staging):
# VITE_SITE_URL=https://arslan-jaffar-portfolio-git-staging-<team>.vercel.app
# VITE_NOINDEX=true

# --- Vercel Development (vercel dev only) ---
# Set in Vercel Dashboard → Environment Variables → Development scope:
# VITE_SITE_URL=http://localhost:3000
# VITE_NOINDEX=true
